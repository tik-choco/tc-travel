# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# mistlib's own git clone cache used by scripts/fetch-mistlib.mjs; the
# built output it produces (src/vendor/mistlib) IS committed.
.mistlib-src

# Environment files can carry private repo URLs / credentials — never commit
# any variant except the placeholder template.
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.omc

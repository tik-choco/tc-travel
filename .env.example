MISTLIB_REPO=git@github.com:<org>/<repo>.git
MISTLIB_REF=develop

# Optional: where the family chat app is reachable, for the Guild screen's
# "Open Chat" hand-off (src/lib/family/guildChatLink.ts). Defaults to the
# same-origin subpath "/tc-chat/" (production: both apps built under one
# static host, see tik-choco/protocol/docs/data-contracts/SHARED_BUS.md).
# Set only for a dev server on a different port, or a separate domain.
# VITE_TC_CHAT_URL=http://localhost:5174/
